    "hadith": [
        {
            "id": "hadith-1",
            "arabic": "إِنَّمَا الْأَعْمَالُ بِالنِّيَّاتِ",
            "transliteration": "Innama al-a'malu bin-niyyat",
            "translation": "Actions are judged by intentions, and every person will get what they intended.",
            "source": "Sahih al-Bukhari, 1",
            "narrator": "Umar ibn al-Khattab",
            "category": "faith"
        },
        {
            "id": "hadith-2",
            "arabic": "لَا يُؤْمِنُ أَحَدُكُمْ حَتَّى يُحِبَّ لِأَخِيهِ مَا يُحِبُّ لِنَفْسِهِ",
            "transliteration": "La yu'minu ahadukum hatta yuhibba li akhihi ma yuhibbu linafsihi",
            "translation": "None of you truly believes until he loves for his brother what he loves for himself.",
            "source": "Sahih al-Bukhari, 13",
            "narrator": "Anas ibn Malik",
            "category": "faith"
        },
        {
            "id": "hadith-3",
            "arabic": "الْمُسْلِمُ مَنْ سَلِمَ الْمُسْلِمُونَ مِنْ لِسَانِهِ وَيَدِهِ",
            "transliteration": "Al-Muslimu man salimal-Muslimuna min lisanihi wa yadihi",
            "translation": "A Muslim is one from whose tongue and hand other Muslims are safe.",
            "source": "Sahih al-Bukhari, 10",
            "narrator": "Abdullah ibn Amr",
            "category": "faith"
        },
        {
            "id": "hadith-4",
            "arabic": "الدِّينُ النَّصِيحَةُ",
            "transliteration": "Ad-dinu an-nasihah",
            "translation": "Religion is sincere advice.",
            "source": "Sahih Muslim, 55",
            "narrator": "Tamim ad-Dari",
            "category": "faith"
        },
        {
            "id": "hadith-5",
            "arabic": "مَنْ كَذَبَ عَلَيَّ مُتَعَمِّدًا فَلْيَتَبَوَّأْ مَقْعَدَهُ مِنَ النَّارِ",
            "transliteration": "Man kadhaba 'alayya muta'ammidan falyatabawwa' maq'adahu minan-nar",
            "translation": "Whoever tells a lie about me deliberately, let him take his seat in the Hellfire.",
            "source": "Sahih al-Bukhari, 107",
            "narrator": "Ali ibn Abi Talib",
            "category": "faith"
        },
        {
            "id": "hadith-6",
            "arabic": "صَلُّوا كَمَا رَأَيْتُمُونِي أُصَلِّي",
            "transliteration": "Sallu kama ra'aytumuni usalli",
            "translation": "Pray as you have seen me praying.",
            "source": "Sahih al-Bukhari, 631",
            "narrator": "Malik ibn al-Huwayrith",
            "category": "worship"
        },
        {
            "id": "hadith-7",
            "arabic": "الطُّهُورُ شَطْرُ الْإِيمَانِ",
            "transliteration": "At-tuhuru shatrul-iman",
            "translation": "Purity is half of faith.",
            "source": "Sahih Muslim, 223",
            "narrator": "Abu Malik al-Ashari",
            "category": "worship"
        },
        {
            "id": "hadith-8",
            "arabic": "مَا مِنْ يَوْمٍ أَفْضَلَ عِنْدَ اللَّهِ مِنْ يَوْمِ الْجُمُعَةِ",
            "transliteration": "Ma min yawmin afdala 'indallahi min yawmil-jumu'ah",
            "translation": "There is no day better in the sight of Allah than Friday.",
            "source": "Sahih Ibn Hibban",
            "narrator": "Abu Hurayrah",
            "category": "worship"
        },
        {
            "id": "hadith-9",
            "arabic": "صِيَامُ يَوْمِ عَرَفَةَ يُكَفِّرُ سَنَتَيْنِ",
            "transliteration": "Siyamu yawmi 'arafah yukaffiru sanatayn",
            "translation": "Fasting on the Day of Arafah expiates the sins of two years.",
            "source": "Sahih Muslim, 1162",
            "narrator": "Abu Qatadah",
            "category": "worship"
        },
        {
            "id": "hadith-10",
            "arabic": "تَبَسُّمُكَ فِي وَجْهِ أَخِيكَ صَدَقَةٌ",
            "transliteration": "Tabassumuka fi wajhi akhika sadaqah",
            "translation": "Your smile to your brother is a charity.",
            "source": "Jami at-Tirmidhi, 1956",
            "narrator": "Abu Dharr",
            "category": "character"
        },
        {
            "id": "hadith-11",
            "arabic": "إِنَّ اللَّهَ رَفِيقٌ يُحِبُّ الرِّفْقَ",
            "transliteration": "Innallaha rafiqun yuhibbur-rifq",
            "translation": "Indeed, Allah is gentle and loves gentleness.",
            "source": "Sahih Muslim, 2593",
            "narrator": "Aisha",
            "category": "character"
        },
        {
            "id": "hadith-12",
            "arabic": "لَيْسَ الشَّدِيدُ بِالصُّرَعَةِ إِنَّمَا الشَّدِيدُ الَّذِي يَمْلِكُ نَفْسَهُ عِنْدَ الْغَضَبِ",
            "transliteration": "Laysal-shadidu bis-sura'ah, innamal-shadidu alladhi yamliku nafsahu 'indal-ghadab",
            "translation": "The strong person is not the one who can wrestle, but the one who controls himself when angry.",
            "source": "Sahih al-Bukhari, 6114",
            "narrator": "Abu Hurayrah",
            "category": "character"
        },
        {
            "id": "hadith-13",
            "arabic": "مَنْ كَانَ يُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الْآخِرِ فَلْيَقُلْ خَيْرًا أَوْ لِيَصْمُتْ",
            "transliteration": "Man kana yu'minu billahi wal-yawmil-akhiri falyaqul khayran aw liyasmut",
            "translation": "Whoever believes in Allah and the Last Day should speak good or remain silent.",
            "source": "Sahih al-Bukhari, 6018",
            "narrator": "Abu Hurayrah",
            "category": "character"
        },
        {
            "id": "hadith-14",
            "arabic": "أَكْمَلُ الْمُؤْمِنِينَ إِيمَانًا أَحْسَنُهُمْ خُلُقًا",
            "transliteration": "Akmalul-mu'minina imanan ahsanuhum khuluqa",
            "translation": "The most complete believers in faith are those with the best character.",
            "source": "Jami at-Tirmidhi, 1162",
            "narrator": "Abu Hurayrah",
            "category": "character"
        },
        {
            "id": "hadith-15",
            "arabic": "طَلَبُ الْعِلْمِ فَرِيضَةٌ عَلَى كُلِّ مُسْلِمٍ",
            "transliteration": "Talabul-'ilmi faridatun 'ala kulli muslim",
            "translation": "Seeking knowledge is an obligation upon every Muslim.",
            "source": "Sunan Ibn Majah, 224",
            "narrator": "Anas ibn Malik",
            "category": "knowledge"
        },
        {
            "id": "hadith-16",
            "arabic": "مَنْ سَلَكَ طَرِيقًا يَلْتَمِسُ فِيهِ عِلْمًا سَهَّلَ اللَّهُ لَهُ طَرِيقًا إِلَى الْجَنَّةِ",
            "transliteration": "Man salaka tariqan yaltamisu fihi 'ilman sahhalallahu lahu tariqan ilal-jannah",
            "translation": "Whoever travels a path seeking knowledge, Allah makes easy for him a path to Paradise.",
            "source": "Sahih Muslim, 2699",
            "narrator": "Abu Hurayrah",
            "category": "knowledge"
        },
        {
            "id": "hadith-17",
            "arabic": "بَلِّغُوا عَنِّي وَلَوْ آيَةً",
            "transliteration": "Ballighu 'anni walaw ayah",
            "translation": "Convey from me, even if it is one verse.",
            "source": "Sahih al-Bukhari, 3461",
            "narrator": "Abdullah ibn Amr",
            "category": "knowledge"
        },
        {
            "id": "hadith-18",
            "arabic": "خَيْرُكُمْ مَنْ تَعَلَّمَ الْقُرْآنَ وَعَلَّمَهُ",
            "transliteration": "Khairukum man ta'allamal-Qurana wa 'allamah",
            "translation": "The best of you are those who learn the Quran and teach it.",
            "source": "Sahih al-Bukhari, 5027",
            "narrator": "Uthman ibn Affan",
            "category": "knowledge"
        },
        {
            "id": "hadith-19",
            "arabic": "خَيْرُكُمْ خَيْرُكُمْ لِأَهْلِهِ",
            "transliteration": "Khairukum khairukum li ahlihi",
            "translation": "The best of you are those who are best to their families.",
            "source": "Jami at-Tirmidhi, 3895",
            "narrator": "Aisha",
            "category": "family"
        },
        {
            "id": "hadith-20",
            "arabic": "مَنْ لَا يَرْحَمُ لَا يُرْحَمُ",
            "transliteration": "Man la yarham la yurham",
            "translation": "He who does not show mercy will not be shown mercy.",
            "source": "Sahih al-Bukhari, 5997",
            "narrator": "Jarir ibn Abdullah",
            "category": "family"
        },
        {
            "id": "hadith-21",
            "arabic": "الْجَارُ قَبْلَ الدَّارِ",
            "transliteration": "Al-jaru qablad-dar",
            "translation": "The neighbor before the house.",
            "source": "Sahih al-Bukhari (implied)",
            "narrator": "Various",
            "category": "family"
        }
    ]
}